{
  "name": "cc-pewpew",
  "version": "0.1.1-pre.0",
  "description": "Desktop GUI for launching and monitoring Claude Code sessions with embedded terminals",
  "author": {
    "name": "Paulo Matos",
    "email": "p@ocmatos.com"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:debug": "electron-vite build && electron --remote-debugging-port=9229 .",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-vite build && electron-builder --publish never",
    "dist:linux": "electron-vite build && electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.cc-pewpew.app",
    "productName": "cc-pewpew",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "hooks/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "electron-devtools-installer": "^4.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.12",
    "vitest": "^4.1.5",
    "zustand": "^5.0.13"
  }
}
